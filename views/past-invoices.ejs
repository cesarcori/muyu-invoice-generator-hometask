<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Past Invoices - Muyu</title>
    <link rel="stylesheet" href="/css/main.css">
    <script src="https://cdn.jsdelivr.net/npm/lucide@0.487.0/dist/umd/lucide.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
    <style>
        .size-6 { width: 1.5rem; height: 1.5rem; }
        .size-4 { width: 1rem; height: 1rem; }
    </style>
</head>
<body class="dark">
    <div class="flex h-screen bg-background" x-init="if (window.lucide) { lucide.createIcons(); }">
        <!-- Sidebar -->
        <aside class="w-64 bg-sidebar border-r border-sidebar-border flex flex-col">
            <div class="p-6 border-b border-sidebar-border">
                <div class="flex items-center gap-2">
                    <i data-lucide="receipt" class="size-6 text-sidebar-foreground"></i>
                    <h1 class="text-lg text-sidebar-foreground">Muyu: Invoice Generator</h1>
                </div>
            </div>

            <nav class="flex-1 p-4">
                <ul class="space-y-1">
                    <li>
                        <a href="/" class="w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm text-muted-foreground hover:text-sidebar-foreground hover:bg-sidebar-accent transition-colors">
                            <i data-lucide="file-text" class="size-4"></i>
                            <span>Create Invoice</span>
                        </a>
                    </li>
                    <li>
                        <a href="/past-invoices" class="w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm text-sidebar-primary-foreground bg-sidebar-primary hover:opacity-90 transition-opacity">
                            <i data-lucide="file-spreadsheet" class="size-4"></i>
                            <span>Past Invoices</span>
                        </a>
                    </li>
                    <li>
                        <a href="/settings" class="w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm text-muted-foreground hover:text-sidebar-foreground hover:bg-sidebar-accent transition-colors">
                            <i data-lucide="settings" class="size-4"></i>
                            <span>Settings</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="p-4 border-t border-sidebar-border">
                <p class="text-xs text-muted-foreground">Logged in as: <%= email %></p>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 overflow-auto">
            <div class="max-w-4xl mx-auto p-8">
                <div class="mb-8">
                    <h2 class="text-2xl text-foreground mb-2">Past Invoices</h2>
                    <p class="text-sm text-muted-foreground">
                        View and re-download your previously generated invoices
                    </p>
                </div>

                <div class="rounded-xl border bg-card text-card-foreground shadow border-border p-0 overflow-hidden">
                    <table class="w-full text-sm text-left">
                        <thead class="bg-muted text-muted-foreground font-medium border-b border-border">
                            <tr>
                                <th class="px-6 py-4">Date</th>
                                <th class="px-6 py-4">Company</th>
                                <th class="px-6 py-4 text-right">Total</th>
                                <th class="px-6 py-4 text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border">
                            <% if (invoices.length === 0) { %>
                                <tr>
                                    <td colspan="4" class="px-6 py-8 text-center text-muted-foreground">
                                        No invoices found for this email.
                                    </td>
                                </tr>
                            <% } else { %>
                                <% invoices.forEach(invoice => { %>
                                    <tr class="hover:bg-accent/50 transition-colors">
                                        <td class="px-6 py-4 text-foreground">
                                            <%= new Date(invoice.created_at).toLocaleDateString() %>
                                        </td>
                                        <td class="px-6 py-4 text-foreground font-medium">
                                            <%= invoice.company_name %>
                                        </td>
                                        <td class="px-6 py-4 text-right text-accent font-mono">
                                            $<%= parseFloat(invoice.total).toFixed(2) %>
                                        </td>
                                        <td class="px-6 py-4 text-center">
                                            <a href="/download/<%= invoice.id %>" class="inline-flex items-center justify-center p-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors" title="Download PDF">
                                                <i data-lucide="download" class="size-4"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
